{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {




    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["generated/**"],
      "cache": true,
      "env": ["DATABASE_URL"]
    },
    "db:migrate":{
      "cache": false,
      "persistent":true
    },
    "db:deploy":{
      "cache":false
    }
  }
}
